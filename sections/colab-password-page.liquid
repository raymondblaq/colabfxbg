<div class="colab-wrap colab-password-wrap">
  <div class="colab-page-card colab-password-card">
    <p class="colab-eyebrow">{{ shop.name }}</p>
    <h1 style="font-size:clamp(36px, 5vw, 54px);">Opening soon.</h1>
    <div class="colab-copy" style="margin-top:14px;">Where founders recover, create, and scale. Enter the password to preview the store.</div>
    {% form 'storefront_password' %}
      {% if form.errors %}
        <div class="colab-errors">{{ form.errors | default_errors }}</div>
      {% endif %}
      <div class="colab-newsletter-grid" style="margin-top:22px;">
        <input class="colab-input colab-input--pill" type="password" name="password" placeholder="Password" required>
        <button class="colab-btn colab-btn--primary" type="submit">Enter</button>
      </div>
    {% endform %}
  </div>
</div>
{% schema %}
{
  "name": "CoLab Password",
  "settings": []
}
{% endschema %}
