{% layout 'none' %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Gift card &ndash; {{ shop.name }}</title>
  {{ content_for_header }}
  <style>
    body { margin: 0; background: #F7F4EE; color: #171717; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 24px; box-sizing: border-box; }
    .gc-card { width: min(560px, 100%); background: rgba(255, 255, 255, 0.85); border: 1px solid rgba(23, 23, 23, 0.08); border-radius: 28px; box-shadow: 0 20px 60px rgba(23, 23, 23, 0.08); padding: 40px 32px; text-align: center; }
    .gc-eyebrow { margin: 0 0 14px; font-size: 12px; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: #8a6944; }
    h1 { margin: 0; font-family: Georgia, 'Times New Roman', serif; font-size: 40px; line-height: 1.05; letter-spacing: -0.02em; }
    .gc-value { margin: 22px 0 8px; font-size: 44px; font-weight: 800; color: #2E3A32; }
    .gc-note { color: #5f5a52; font-size: 15px; line-height: 1.7; margin: 8px 0; }
    .gc-code { display: inline-block; margin: 18px 0; padding: 16px 22px; border-radius: 16px; border: 2px dashed rgba(23, 23, 23, 0.16); background: #ffffff; font-size: 20px; font-weight: 800; letter-spacing: 0.14em; }
    .gc-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 20px; }
    .gc-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 50px; padding: 0 22px; border-radius: 999px; font-size: 15px; font-weight: 700; text-decoration: none; border: 1px solid transparent; cursor: pointer; font-family: inherit; }
    .gc-btn--primary { background: #B38A5A; color: #ffffff; }
    .gc-btn--secondary { background: transparent; color: #171717; border-color: rgba(23, 23, 23, 0.16); }
    @media print { .gc-actions { display: none; } }
  </style>
</head>
<body>
  <div class="gc-card">
    <p class="gc-eyebrow">{{ shop.name }}</p>
    <h1>Here&rsquo;s your gift card</h1>
    <div class="gc-value">{{ gift_card.initial_value | money }}</div>
    {% if gift_card.enabled != true or gift_card.expired %}
      <p class="gc-note">This gift card has expired.</p>
    {% endif %}
    {% if gift_card.balance != gift_card.initial_value %}
      <p class="gc-note">Remaining balance: {{ gift_card.balance | money }}</p>
    {% endif %}
    <div class="gc-code">{{ gift_card.code | format_code }}</div>
    <p class="gc-note">Use this code at checkout to redeem your gift card.</p>
    <div class="gc-actions">
      <a class="gc-btn gc-btn--primary" href="{{ shop.url }}">Start shopping</a>
      <button class="gc-btn gc-btn--secondary" onclick="window.print();">Print</button>
    </div>
  </div>
</body>
</html>
