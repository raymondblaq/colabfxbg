{% layout 'none' %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#0a0a0a">
  <title>Gift card &ndash; {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400..700&family=Geist+Mono:wght@400..600&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    body { margin: 0; background: #0a0a0a; color: #ededed; font-family: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; -webkit-font-smoothing: antialiased; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 24px; box-sizing: border-box; }
    .gc-card { width: min(560px, 100%); background: #111111; border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 20px; padding: 40px 32px; text-align: center; }
    .gc-eyebrow { margin: 0 0 14px; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 12px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: #d4b483; }
    h1 { margin: 0; font-size: 32px; font-weight: 600; line-height: 1.1; letter-spacing: -0.03em; color: #ededed; }
    .gc-value { margin: 22px 0 8px; font-size: 40px; font-weight: 600; letter-spacing: -0.02em; color: #ededed; }
    .gc-note { color: #a1a1a1; font-size: 15px; line-height: 1.65; margin: 8px 0; }
    .gc-code { display: inline-block; margin: 18px 0; padding: 14px 22px; border-radius: 12px; border: 1px dashed rgba(255, 255, 255, 0.2); background: #0a0a0a; font-family: 'Geist Mono', ui-monospace, monospace; font-size: 18px; font-weight: 500; letter-spacing: 0.12em; color: #ededed; }
    .gc-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 20px; }
    .gc-btn { display: inline-flex; align-items: center; justify-content: center; min-height: 46px; padding: 0 24px; border-radius: 999px; font-size: 14px; font-weight: 500; text-decoration: none; border: 1px solid transparent; cursor: pointer; font-family: inherit; transition: background-color 0.2s ease, border-color 0.2s ease; }
    .gc-btn--primary { background: #ffffff; color: #0a0a0a; }
    .gc-btn--primary:hover { background: #d4d4d4; }
    .gc-btn--secondary { background: transparent; color: #ededed; border-color: rgba(255, 255, 255, 0.14); }
    .gc-btn--secondary:hover { background: rgba(255, 255, 255, 0.06); border-color: rgba(255, 255, 255, 0.24); }
    @media print { .gc-actions { display: none; } body { background: #ffffff; color: #171717; } .gc-card { border-color: rgba(0,0,0,0.1); background: #ffffff; } h1, .gc-value, .gc-code { color: #171717; } }
  </style>
</head>
<body>
  <div class="gc-card">
    <p class="gc-eyebrow">{{ shop.name }}</p>
    <h1>Here&rsquo;s your gift card</h1>
    <div class="gc-value">{{ gift_card.initial_value | money }}</div>
    {% if gift_card.enabled != true or gift_card.expired %}
      <p class="gc-note">This gift card has expired.</p>
    {% endif %}
    {% if gift_card.balance != gift_card.initial_value %}
      <p class="gc-note">Remaining balance: {{ gift_card.balance | money }}</p>
    {% endif %}
    <div class="gc-code">{{ gift_card.code | format_code }}</div>
    <p class="gc-note">Use this code at checkout to redeem your gift card.</p>
    <div class="gc-actions">
      <a class="gc-btn gc-btn--primary" href="{{ shop.url }}">Start shopping</a>
      <button class="gc-btn gc-btn--secondary" onclick="window.print();">Print</button>
    </div>
  </div>
</body>
</html>
